# Copy to .env and replace with values from Supabase → Project Settings → API.
# Placeholder values are ignored; the dashboard can run without auth until real keys are set.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# TPStreams — course intro / material video playback (embed credentials)
VITE_TPSTREAMS_ORG_ID=your-tpstreams-org-id
VITE_TPSTREAMS_ACCESS_TOKEN=your-tpstreams-access-token
